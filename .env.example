# Trafiklab API keys
# Register at https://www.trafiklab.se/ and create a project
# Add the "GTFS Regional" API to your project to get keys

# Option 1: Single key (used for both static and realtime if separate keys not set)
# TRAFIKLAB_API_KEY=your-api-key-here

# Option 2: Separate keys (from Trafiklab project settings)
TRAFIKLAB_GTFS_RT_KEY=your-gtfs-rt-api-key-here
TRAFIKLAB_GTFS_STATIC_KEY=your-gtfs-static-api-key-here

# Oxyfi Realtidspositionering — live train positions (Tåg i Bergslagen, Norrtåg, Värmlandstrafik m.fl.)
# Register at https://www.trafiklab.se/ and add "Oxyfi-Realtidspositionering" to your project
# Leave empty to disable train tracking
OXYFI_API_KEY=your-oxyfi-api-key-here

# Trafikverket open API — train positions (SJ, Mälartåg, TiB) + departure boards
# Register at https://api.trafikinfo.trafikverket.se/ to get a key
# Leave empty to disable Trafikverket integration
TRAFIKVERKET_API_KEY=your-trafikverket-api-key-here

# Stations to show on the TiB departure board, as "gtfs_stop_id:loc_sig" pairs (comma-separated)
# loc_sig = Trafikverket location signature, e.g. Örc = Örebro C, Örs = Örebro Södra
# Example: TRAFIKVERKET_STATIONS=9022:Örc,9023:Örs
TRAFIKVERKET_STATIONS=

# Filter announcements to specific operators (comma-separated, leave empty for all)
# Example: TRAFIKVERKET_OPERATORS=Arriva Sverige AB
TRAFIKVERKET_OPERATORS=

# How far ahead to fetch train announcements (minutes, default 120)
# TRAFIKVERKET_LOOKAHEAD_MINUTES=120

# How often to poll Trafikverket API (seconds, default 60)
# TRAFIKVERKET_POLL_SECONDS=60

# How far to search for nearby stops when using GPS (metres, default 400)
NEARBY_RADIUS_METERS=400

# How often the frontend polls for vehicle positions (milliseconds, default 5000)
FRONTEND_POLL_INTERVAL_MS=5000
