# =============================================================================
# LTlive — Konfiguration
# Kopiera till .env och fyll i dina värden.
# .env är den enda platsen du behöver redigera för att konfigurera appen.
# =============================================================================


# -----------------------------------------------------------------------------
# Operatör & region
# -----------------------------------------------------------------------------

# Operatörs-ID för Samtrafiken GTFS-flödet (används i URL-sökvägen).
# Kör /api/debug/agencies efter uppstart för att se tillgängliga operatörer.
OPERATOR=orebro

# Tidszon för backend-loggning och schemaläggning.
TZ=Europe/Stockholm


# -----------------------------------------------------------------------------
# Kartkonfiguration (frontend)
# -----------------------------------------------------------------------------

# Kartans centrumpunkt vid start (decimal-grader).
MAP_CENTER_LAT=59.2753
MAP_CENTER_LON=15.2134

# Standard-zoomnivå vid start (Leaflet zoom, 1–18).
MAP_DEFAULT_ZOOM=13


# -----------------------------------------------------------------------------
# Trafiklab — API-nycklar
# Registrera på https://www.trafiklab.se/ och skapa ett projekt.
# Lägg till "GTFS Regional" och eventuellt "Oxyfi-Realtidspositionering".
# -----------------------------------------------------------------------------

# Alternativ 1: En gemensam nyckel för både statisk och realtidsdata.
# TRAFIKLAB_API_KEY=din-nyckel-här

# Alternativ 2: Separata nycklar (rekommenderas för produktionsmiljö).
TRAFIKLAB_GTFS_RT_KEY=din-gtfs-rt-nyckel-här
TRAFIKLAB_GTFS_STATIC_KEY=din-gtfs-statisk-nyckel-här

# Oxyfi Realtidspositionering — live-positioner för Tåg i Bergslagen m.fl.
# Lämna tomt för att inaktivera tågspårning via Oxyfi.
OXYFI_API_KEY=din-oxyfi-nyckel-här


# -----------------------------------------------------------------------------
# Trafikverket — API-nyckel och stationskonfiguration
# Registrera på https://api.trafikinfo.trafikverket.se/ (gratis, separat från Trafiklab).
# Lämna tomt för att inaktivera Trafikverket-integrationen.
# -----------------------------------------------------------------------------

TRAFIKVERKET_API_KEY=din-trafikverket-nyckel-här

# Stationer att visa på TiB-avgångstavlan, som "gtfs_stop_id:platssignatur"-par (kommaseparerat).
# Platssignatur = Trafikverkets förkortning, t.ex. Örc = Örebro C, Örs = Örebro Södra.
# Kör /api/debug/stops för GTFS stop_id och /api/debug/tv-stations för platssignaturer.
# Exempel: TRAFIKVERKET_STATIONS=9022:Örc,9023:Örs
TRAFIKVERKET_STATIONS=

# Filtrera avgångsdata till specifika operatörer (kommaseparerat, skiftlägeskänsligt).
# Förhindrar felaktiga matchningar när en station trafikeras av flera operatörer.
# Exempel: TRAFIKVERKET_OPERATORS=Arriva Sverige AB
# Lämna tomt för att visa alla operatörer.
TRAFIKVERKET_OPERATORS=

# Hur många minuter framåt tågannonseringar hämtas (standard: 120).
TRAFIKVERKET_LOOKAHEAD_MINUTES=120

# Hur ofta Trafikverkets API pollas (sekunder, standard: 60).
TRAFIKVERKET_POLL_SECONDS=60

# Centrum och sökradie för TrainPosition-filtrering.
# Alla aktiva tåg inom radien visas på kartan.
# Standard: Örebro C. Ändra vid driftsättning i annan region.
TV_POSITION_CENTER_LAT=59.2753
TV_POSITION_CENTER_LON=15.2134
TV_POSITION_RADIUS_KM=150


# -----------------------------------------------------------------------------
# TiB-linjefiltrering (Tåg i Bergslagen)
# -----------------------------------------------------------------------------

# Agency-ID för Tåg i Bergslagen i Samtrafiken GTFS.
# Lämna tomt för att visa alla tågoperatörer.
# Kör /api/debug/agencies för att hitta rätt värde.
TIB_AGENCY_ID=

# Kommaseparerad lista med route_short_name att inkludera i avgångstavlor.
# Har prioritet framför TIB_AGENCY_ID. Lämna tomt för inget filter.
# Kör /api/routes/trains för tillgängliga linjenamn.
# Exempel: TIB_ROUTE_SHORT_NAMES=T53,T63,T66,T68,T72
TIB_ROUTE_SHORT_NAMES=

# Överskrid linjetfärger från GTFS-data (kommaseparerat "LINJENAMN:RRGGBB"-format).
# TiB brandgrön: 2C6E37. Exempel: ROUTE_COLOR_OVERRIDES=T53:2C6E37,T63:2C6E37
ROUTE_COLOR_OVERRIDES=


# -----------------------------------------------------------------------------
# Polling & uppdateringsintervall
# -----------------------------------------------------------------------------

# Hur ofta GTFS-RT (realtidsdata) hämtas från Trafiklab (sekunder, standard: 5).
# Bronze-tier: använd minst 180. Silver-tier: 5 är ok.
RT_POLL_SECONDS=5

# Hur ofta GTFS-statisk data laddas om (timmar, standard: 24).
GTFS_REFRESH_HOURS=24

# Hur ofta frontenden pollar vid SSE-avbrott (millisekunder, standard: 5000).
FRONTEND_POLL_INTERVAL_MS=5000


# -----------------------------------------------------------------------------
# GPS & platsbaserade funktioner
# -----------------------------------------------------------------------------

# Sökradie för "Hållplatser i närheten"-funktionen (meter, standard: 400, max: 5000).
NEARBY_RADIUS_METERS=400


# -----------------------------------------------------------------------------
# Felsökning & diagnostik
# -----------------------------------------------------------------------------

# Aktivera /api/debug/*-endpoints (true/false).
# Dessa exponeras aldrig externt (Nginx blockerar dem utanför LAN)
# men bör ändå sättas till false i produktionsmiljö om LAN-åtkomst inte önskas.
ENABLE_DEBUG_ENDPOINTS=false
